rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['dailyGoal', 'email']) 
        && data.dailyGoal is number && data.dailyGoal >= 0 && data.dailyGoal <= 10000
        && data.email is string && data.email.size() <= 256
        && (!('personalDetails' in data) || isValidPersonalDetails(data.personalDetails));
    }

    function isValidPersonalDetails(data) {
      return data.keys().hasAll(['weight', 'height', 'age', 'gender', 'activityLevel', 'bulkIntensity'])
        && data.keys().size() == 6
        && data.weight is number && data.weight > 0
        && data.height is number && data.height > 0
        && data.age is number && data.age > 0
        && data.gender in ['male', 'female']
        && data.activityLevel in ['sedentary', 'light', 'moderate', 'active', 'very_active']
        && data.bulkIntensity in ['clean', 'standard', 'aggressive'];
    }

    function isValidRecipe(data) {
      return data.keys().hasAll(['name', 'calories', 'protein', 'carbs', 'fats', 'ingredients', 'instructions', 'description'])
        && data.name is string && data.name.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.ingredients is list && data.instructions is list
        && data.calories is number && data.protein is number && data.carbs is number && data.fats is number;
    }

    function isValidFoodLog(data) {
      return data.keys().hasAll(['name', 'calories', 'protein', 'carbs', 'fats', 'timestamp', 'userId'])
        && data.keys().size() == 7
        && data.name is string && data.name.size() <= 128
        && data.calories is number && data.calories >= 0
        && data.protein is number && data.protein >= 0
        && data.carbs is number && data.carbs >= 0
        && data.fats is number && data.fats >= 0
        && data.timestamp is number
        && data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['dailyGoal', 'displayName', 'personalDetails']);
    }

    match /users/{userId}/logs/{logId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(logId) && isValidFoodLog(incoming());
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/recipes/{recipeId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(recipeId) && isValidRecipe(incoming());
      allow delete: if isOwner(userId);
    }
  }
}
